{% extends 'admin/layout.html.twig' %}

{% block title %}Users - Admin{% endblock %}

{% block admin_body %}
    <h1>Users</h1>

    <div class="data-table-wrap">
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Username</th>
                <th>Telegram ID</th>
                <th>Daily Limit</th>
                <th>Role</th>
                <th>Status</th>
                <th>Pack</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
                <tr>
                    <td>{{ user.id }}</td>
                    <td>{{ user.firstName }}</td>
                    <td>{{ user.username ? '@' ~ user.username : '—' }}</td>
                    <td><span class="badge badge-orange">{{ user.telegramId }}</span></td>
                    <td>{{ user.dailyLimit }}</td>
                    <td>
                        {% if user.admin %}
                            <span class="badge" style="background:rgba(255,107,53,0.15);color:#ff6b35;">Admin</span>
                        {% else %}
                            <span style="color:#555;">User</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if user.banned %}
                            <span class="badge" style="background:rgba(255,51,102,0.15);color:#ff3366;">Banned</span>
                        {% else %}
                            <span class="badge" style="background:rgba(52,211,153,0.15);color:#34d399;">Active</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if user.activeStickerPack %}
                            <a href="{{ path('gallery_pack', {id: user.activeStickerPack.id}) }}">View</a>
                            {% if user.stickerPacks|length > 1 %}
                                ({{ user.stickerPacks|length }} packs)
                            {% endif %}
                        {% elseif user.stickerPacks|length > 0 %}
                            <a href="{{ path('gallery_pack', {id: user.stickerPacks|first.id}) }}">View</a>
                        {% else %}
                            —
                        {% endif %}
                    </td>
                    <td><a href="{{ path('admin_user_edit', {id: user.id}) }}" class="btn btn-ghost">Edit</a></td>
                </tr>
            {% else %}
                <tr><td colspan="9" style="text-align:center;color:#555;padding:2rem;">No users yet.</td></tr>
            {% endfor %}
        </tbody>
    </table>
    </div>
{% endblock %}
