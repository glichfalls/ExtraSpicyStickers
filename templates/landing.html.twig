<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Extra Spicy Stickers</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0f0f0f;
            color: #e0e0e0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .container {
            max-width: 600px;
            padding: 2rem;
            text-align: center;
        }

        .logo {
            font-size: 4rem;
            margin-bottom: 1rem;
        }

        h1 {
            font-size: 2.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, #ff6b35, #ff3366, #ff6b35);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradient 3s ease infinite;
            margin-bottom: 0.5rem;
        }

        @keyframes gradient {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        .tagline {
            font-size: 1.1rem;
            color: #888;
            margin-bottom: 2.5rem;
        }

        .steps {
            text-align: left;
            margin-bottom: 2.5rem;
        }

        .step {
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            margin-bottom: 1.2rem;
            padding: 1rem;
            background: #1a1a1a;
            border-radius: 12px;
            border: 1px solid #2a2a2a;
        }

        .step-icon {
            font-size: 1.5rem;
            flex-shrink: 0;
        }

        .step-text {
            font-size: 0.95rem;
            line-height: 1.5;
        }

        .step-text strong {
            color: #fff;
        }

        .step-text code {
            background: #2a2a2a;
            padding: 0.15rem 0.4rem;
            border-radius: 4px;
            font-size: 0.85rem;
            color: #ff6b35;
        }

        .cta {
            display: inline-block;
            padding: 0.9rem 2rem;
            background: linear-gradient(135deg, #ff6b35, #ff3366);
            color: #fff;
            text-decoration: none;
            border-radius: 50px;
            font-size: 1.1rem;
            font-weight: 600;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .cta:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(255, 107, 53, 0.3);
        }

        .footer {
            margin-top: 3rem;
            font-size: 0.8rem;
            color: #555;
        }

        .footer a {
            color: #777;
            text-decoration: none;
        }

        .footer a:hover {
            color: #aaa;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="logo">🌶️</div>
        <h1>Extra Spicy Stickers</h1>
        <p class="tagline">AI-powered Telegram sticker generator</p>

        <div class="steps">
            <div class="step">
                <span class="step-icon">💬</span>
                <div class="step-text">
                    <strong>Use the /sticker command</strong><br>
                    Send <code>/sticker 🐱 happy orange cat</code> in any chat with the bot
                </div>
            </div>
            <div class="step">
                <span class="step-icon">🎨</span>
                <div class="step-text">
                    <strong>AI generates your sticker</strong><br>
                    Powered by OpenAI image generation, your idea becomes a sticker in seconds
                </div>
            </div>
            <div class="step">
                <span class="step-icon">📦</span>
                <div class="step-text">
                    <strong>Auto-added to your pack</strong><br>
                    Each sticker is saved to your personal sticker pack for easy reuse
                </div>
            </div>
        </div>

        <a href="https://t.me/{{ bot_username }}" class="cta">Open in Telegram</a>

        <div class="footer">
            <a href="https://github.com/glichfalls/ExtraSpicyStickers">GitHub</a>
        </div>
    </div>
</body>
</html>