<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Extra Spicy Stickers{% endblock %}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0f0f0f;
            color: #e0e0e0;
            min-height: 100vh;
        }

        a { color: #ff6b35; text-decoration: none; }
        a:hover { color: #ff3366; }

        .nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            height: 56px;
            background: rgba(15, 15, 15, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-left {
            display: flex;
            align-items: center;
            gap: 2rem;
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 1.1rem;
            font-weight: 600;
            color: #fff;
            text-decoration: none;
            letter-spacing: -0.02em;
        }

        .nav-logo-icon {
            font-size: 1.3rem;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }

        .nav-links a {
            color: #777;
            font-size: 0.875rem;
            font-weight: 500;
            padding: 0.4rem 0.75rem;
            border-radius: 8px;
            transition: color 0.15s, background 0.15s;
        }

        .nav-links a:hover {
            color: #e0e0e0;
            background: rgba(255, 255, 255, 0.06);
        }

        .nav-cta {
            font-size: 0.8rem;
            font-weight: 500;
            padding: 0.4rem 1rem;
            background: linear-gradient(135deg, #ff6b35, #ff3366);
            color: #fff !important;
            border-radius: 20px;
            transition: opacity 0.15s, transform 0.15s;
        }

        .nav-cta:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            background: linear-gradient(135deg, #ff6b35, #ff3366) !important;
        }

        {% block styles %}{% endblock %}
    </style>
</head>
<body>
    <nav class="nav">
        <div class="nav-left">
            <a href="{{ path('landing') }}" class="nav-logo">
                <span class="nav-logo-icon">🌶️</span> Extra Spicy
            </a>
            <div class="nav-links">
                <a href="{{ path('gallery') }}">Gallery</a>
            </div>
        </div>
        <a href="https://t.me/{{ bot_username }}" class="nav-cta">Open Bot</a>
    </nav>
    {% block body %}{% endblock %}
</body>
</html>