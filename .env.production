# Production Environment Configuration
# Copy this to .env.local on the server and fill in the values

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_BOT_USERNAME=your_bot_username_without_at

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Database (MySQL via Plesk)
DATABASE_URL="mysql://sticker_bot:your_password@localhost:3306/sticker_bot?serverVersion=8.0&charset=utf8mb4"

# Sentry
SENTRY_DSN=your_sentry_dsn